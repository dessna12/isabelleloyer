---
import Layout from '../layouts/Layout.astro'
import AccompHero from '../components/accompagnements/AccompHero/AccompHero'
import AccompCard from '../components/accompagnements/AccompCard/AccompCard'
import AccompSigns from '../components/accompagnements/AccompSigns/AccompSigns'
import AccompMethod from '../components/accompagnements/AccompMethod/AccompMethod'
import AccompFAQ from '../components/accompagnements/AccompFAQ/AccompFAQ'
import '../pages-styles/accompagnements.css'

const accompagnements = [
  {
    number: '01',
    quote: "Je me sens prisonnière de ma relation",
    title: "La relation à l'autre",
    type: "Accompagnement de l'emprise et de la dépendance affective",
    situation: "Vous vous demandez : « Est-ce que je suis dans une relation toxique ? ». Vous avez l'impression de marcher sur des œufs, de tout faire de travers, et pourtant, vous n'arrivez pas à partir. Vous vous sentez vidée, confuse, et vous finissez par croire que vous êtes le problème.",
    aide: "Nous décodons ensemble les mécanismes de l'emprise et de la manipulation. Je vous aide à restaurer votre discernement (votre « boussole » intérieure) pour que vous puissiez, à votre rythme, sortir de la confusion et reprendre votre pouvoir.",
  },
  {
    number: '02',
    quote: "Je porte un vécu qui m'empêche d'avancer",
    title: "Le poids du passé",
    type: "Réparation des traumatismes d'enfance et des blessures de lien",
    situation: "Vous avez le sentiment de ne jamais être tout à fait à votre place. Vous portez peut-être un secret, ou vous avez grandi dans un climat où les limites n'étaient pas respectées (parentification, climat incestuel). Aujourd'hui, cela se traduit par une peur constante de l'abandon ou une incapacité à dire « non ».",
    aide: "Nous travaillons à « prouver » à votre système nerveux que ce passé est terminé. Sans vous forcer à revivre les détails douloureux, nous réparons vos fondations intérieures pour que vous vous sentiez enfin légitime et en sécurité dans le présent.",
  },
  {
    number: '03',
    quote: "Mon corps ou mon espace n'ont pas été respectés",
    title: "L'atteinte à l'intégrité",
    type: "Accompagnement des victimes de viols, d'agressions sexuelles ou de violences conjugales",
    situation: "Vous vivez avec les traces d'une violence qui a brisé votre sentiment de sécurité. Que cela soit récent ou ancien, vous cohabitez peut-être avec des flash-backs, des cauchemars, une sensation de déconnexion de votre corps ou une peur qui ne vous quitte jamais. Le poids de la honte ou du secret vous empêche de vous reconstruire pleinement.",
    aide: "Mon cabinet est un sanctuaire où votre parole est sacrée et crue sans réserve. Nous travaillons à apaiser la mémoire traumatique logée dans votre corps (la sidération, l'hyper-vigilance) pour que vous ne soyez plus prisonnière du passé. L'objectif est de vous aider à vous réapproprier votre corps, votre espace et votre dignité, en douceur et sans jamais vous forcer à revivre l'effraction.",
  },
  {
    number: '04',
    quote: "Je compense mon stress par la nourriture ou l'alcool",
    title: "Les mécanismes de survie",
    type: "Régulation des compulsions et des comportements addictifs",
    situation: "Quand l'angoisse monte, c'est plus fort que vous : vous mangez sans faim ou vous avez besoin de ce verre pour « éteindre » votre cerveau. Après, la honte vous submerge. Vous avez l'impression de manquer de volonté, alors que c'est votre corps qui cherche désespérément à s'apaiser.",
    aide: "Au lieu de lutter contre le comportement, nous traitons la source : l'angoisse profonde ou le trauma caché. En apaisant la source de la tension grâce à l'intégration émotionnelle, le besoin de compenser diminue naturellement.",
  },
  {
    number: '05',
    quote: "Notre couple est dans une impasse",
    title: "La vie à deux",
    type: "Thérapie de couple et médiation relationnelle",
    situation: "« On ne se comprend plus ». Les disputes éclatent pour des détails, ou au contraire, le silence s'est installé. Vous sentez que vos blessures personnelles (jalousie, peur de la trahison, hyper-contrôle) s'invitent dans vos échanges et gâchent votre lien.",
    aide: "Je vous offre un espace neutre pour comprendre « qui parle » pendant la crise. L'objectif est de désamorcer les schémas répétitifs pour restaurer une communication sécurisante et décider ensemble de l'avenir.",
  },
]
---

<Layout
  title="Mes accompagnements thérapeutiques — Isabelle Loyer, thérapeute"
  description="Accompagnement thérapeutique. Thérapie au Cannet et en visio : psychotrauma, difficultés relationnelles et de couples, TCA et hypersensibilité."
>
  <main class="accomp-main">
    <AccompHero client:load />

    <section class="accomp-sections">
      {accompagnements.map(a => <AccompCard client:load a={a} />)}
    </section>

    <AccompSigns client:load />
    <AccompMethod client:load />
    <AccompFAQ client:load />

    <div class="accomp-cta reveal">
      <h2 class="accomp-cta__title">Prête à retrouver votre sérénité ?</h2>
      <p class="accomp-cta__text">
        Faire une thérapie, c'est passer d'un état où vous subissez vos réactions
        à un état où vous comprenez votre système pour enfin choisir votre vie.
      </p>
      <a href="#contact" class="accomp-cta__link">Prendre rendez-vous</a>
    </div>
  </main>
</Layout>
