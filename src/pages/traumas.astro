---
import Layout from '../layouts/Layout.astro'
import TraumaHero from '../components/trauma/TraumaHero/TraumaHero'
import SectionCard from '../components/trauma/SectionCard/SectionCard'
import TraumaQuote from '../components/trauma/TraumaQuote/TraumaQuote'
import '../pages-styles/trauma.css'

const sections = [
  {
    number: '01',
    title: "L'emprise et les blessures relationnelles",
    target: "Les personnes sous emprise ou en relation toxique",
    intro:
      "L'emprise ne laisse pas de traces visibles, mais elle \"brouille\" votre réalité. Ce sentiment d'être perdu·e, coupable ou épuisé·e n'est pas une preuve de votre sensibilité.",
    lived: [
      "Le doute permanent : Vous finissez par croire que vous êtes le seul problème dans la relation.",
      "La paralysie : Vous savez que la situation est toxique, mais vous vous sentez incapable de partir ou de dire \"non\".",
      "La culpabilité chronique : Vous vous excusez sans cesse et portez seul·e le poids des émotions de l'autre.",
    ],
  },
  {
    number: '02',
    title: "Les racines de l'enfance : du climat \"incestuel\" à l'absence de limites",
    target: "Les adultes marqués par leur passé familial",
    intro:
      "Les blessures de l'enfance ne sont pas toujours des chocs brutaux ; elles sont souvent le résultat d'un climat familial où l'on a dû se \"sur-adapter\" pour survivre.",
    lived: [
      "La peur de l'abandon : Une insécurité profonde qui vous pousse à anticiper le rejet avant même qu'il ne survienne.",
      "Le sentiment d'illégitimité : L'impression constante de devoir \"faire plus\" ou \"être parfait·e\" pour mériter votre place ou votre valeur.",
    ],
  },
  {
    number: '03',
    title: "Le traumatisme des violences (Sexuelles, Conjugales, Physiques)",
    target: "Les personnes ayant vécu un viol, une agression sexuelle ou des violences conjugales",
    intro:
      "Après une agression, votre corps n'a pas \"oublié\". Il est resté bloqué en état d'alerte maximale ou, au contraire, en état de sidération.",
    lived: [
      "L'état d'alerte constant : Une vigilance extrême, des flashbacks ou une impression d'être en danger permanent.",
      "Le poids du passé : Un sentiment de honte, de salissure qui vous empêche de vous sentir en sécurité, même dans les moments de calme.",
    ],
  },
  {
    number: '04',
    title: "Quand le corps cherche à s'apaiser (Compulsions & Addictions)",
    target: "Les personnes souffrant de troubles alimentaires ou de dépendances",
    intro:
      "L'alcool, la nourriture ou les comportements compulsifs ne sont pas des faiblesses, mais des stratégies de survie. Votre corps utilise ces béquilles pour \"anesthésier\" une angoisse.",
    lived: [
      "La honte et le piège : Une perte de contrôle suivie d'un dégoût de soi et d'une culpabilité dévorante.",
      "Le besoin d'anesthésie : Une sensation d'urgence à compenser une tension interne pour éviter de ressentir un vide insupportable.",
    ],
  },
  {
    number: '05',
    title: "Le trauma au cœur du couple",
    target: "Les couples en crise ou impactés par des blessures anciennes",
    intro:
      "Les tensions dans votre couple ne sont souvent que le miroir de vos histoires personnelles. Vos réactions sont des réflexes de protection qui s'activent lorsque vous vous sentez en insécurité.",
    lived: [
      "Les conflits en boucle : Les mêmes disputes reviennent sans fin, sans que vous n'arriviez à en sortir.",
      "L'incompréhension mutuelle : L'impression de parler deux langues différentes.",
      "Le sentiment d'insécurité : Vous vous sentez en alerte ou sur la défensive dans la relation.",
    ],
  },
]
---

<Layout
  title="Comprendre ses traumas — Isabelle Loyer, thérapeute"
  description="Emprise, blessures d'enfance, compulsions, trauma de couple : découvrez comment ces expériences s'inscrivent dans votre vie et comment la thérapie peut vous aider à les intégrer."
>
  <main class="trauma-main">
    <TraumaHero client:load />

    <section class="trauma-sections">
      {sections.map(s => <SectionCard client:load s={s} />)}
    </section>


    <div class="trauma-cta reveal">
      <p class="trauma-cta__text">Découvrez mes méthodes pour vous aider</p>
      <a href="/mes-accompagnements-therapeutiques" class="trauma-cta__link">Voir les accompagnements</a>
    </div>
  </main>
</Layout>
